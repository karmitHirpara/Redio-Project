PORT=3001
# Use an absolute path on servers (recommended). Example:
# DATABASE_PATH=/var/lib/redio/database.sqlite
DATABASE_PATH=./database.sqlite

# Use an absolute path on servers (recommended). Example:
# UPLOAD_PATH=/var/lib/redio/uploads
UPLOAD_PATH=./uploads

# Comma-separated allowed frontend origins (for production set your domain)
# Example: CORS_ORIGIN=https://redio.yourdomain.com
CORS_ORIGIN=http://localhost:5173

# Optional
# SCHEDULER_INTERVAL_MS=1000
# SCHEDULER_DEBUG=0
