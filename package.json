{
  "name": "radio-automation-frontend",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "predev": "node scripts/kill-ports.cjs",
    "dev:frontend": "vite",
    "dev:backend": "npm run dev --prefix server",
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:electron": "electron .",
    "dev:desktop": "concurrently \"npm:dev:frontend\" \"npm:dev:electron\"",
    "license:fingerprint": "node scripts/print-fingerprint.cjs",
    "license:gen-keys": "node scripts/generate-keypair.cjs",
    "license:gen": "node scripts/generate-license.cjs",
    "license:gen-activation": "node scripts/generate-activation.cjs",
    "init-db": "npm run init-db --prefix server",
    "rebuild:electron": "electron-rebuild -f -w sqlite3 && electron-rebuild -f -w sqlite3 --module-dir server",
    "typecheck": "tsc --noEmit",
    "build:web": "vite build",
    "verify": "npm run typecheck && npm run build:web",
    "build:desktop": "node scripts/build-desktop.cjs",
    "build:desktop:demo": "set REDIO_INSTALL_PASSWORD_HASH=d3ad9315b7be5dd53b31a273b3b3aba5defe700808305aa16a3062b76658a791&& npm run build:desktop",
    "build:desktop:demo:ps": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:REDIO_INSTALL_PASSWORD_HASH='d3ad9315b7be5dd53b31a273b3b3aba5defe700808305aa16a3062b76658a791'; npm run build:desktop\"",
    "preview": "vite preview",
    "lint": "echo 'no lint configured'"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-context-menu": "^2.2.6",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toggle": "^1.1.2",
    "@radix-ui/react-toggle-group": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/multer": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "crypto": "^1.0.1",
    "embla-carousel-react": "^8.6.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^11.18.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.487.0",
    "motion": "^12.23.24",
    "multer": "^2.0.2",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.55.0",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.15.2",
    "sonner": "^1.7.4",
    "systeminformation": "^5.30.2",
    "tailwind-merge": "^2.6.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^30.5.1",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "build": {
    "appId": "com.yourcompany.redio",
    "productName": "Redio",
    "asarUnpack": [
      "**/*.node"
    ],
    "directories": {
      "buildResources": "electron/assets",
      "output": "release"
    },
    "nsis": {
      "oneClick": false,
      "include": "build/installer.nsh"
    },
    "files": [
      "dist/**",
      "server/**",
      "!server/backups/**",
      "!server/uploads/**",
      "!server/database.sqlite",
      "!server/*.sqlite",
      "!server/**/*.sqlite",
      "!server/**/*.sqlite-journal",
      "!server/**/*.sqlite-wal",
      "!server/**/*.sqlite-shm",
      "electron/**",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "node_modules/app-builder-lib/templates/icons/proton-native/proton-native.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "electron/assets/icon.png"
    }
  }
}
